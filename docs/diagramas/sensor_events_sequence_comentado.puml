@startuml
' Inicia el diagrama PlantUML.

title Flujo extremo a extremo de sensor_events
' Título visible del diagrama.
' Resume que vamos a seguir solo un dataset: sensor_events.

autonumber
' Numera automáticamente cada mensaje del diagrama.
' Esto sirve mucho para estudiar el orden real de ejecución.

actor Usuario as U
' "actor" representa una entidad externa al sistema.
' Aquí es la persona que ejecuta el proyecto desde terminal.

participant "run_pipeline.py" as RP
' Participante que representa el script de arranque operativo.

participant "main.py" as M
' Participante que representa el orquestador global del sistema.

participant "settings.py" as S
' Participante que representa el módulo de configuración centralizada.

participant "logger.py" as LG
' Participante que representa la infraestructura de logging.

participant "pipelines.py" as P
' Participante que representa el orquestador de datasets.

participant "readers.py" as R
' Participante que representa el módulo de lectura Bronze.

participant "schemas.py" as SC
' Participante que representa el catálogo de esquemas.

database "Bronze\nsensor_events.csv" as B
' "database" se usa aquí como recurso externo o almacenamiento.
' Representa el archivo físico Bronze de sensor_events.

participant "validators.py" as V
' Participante que representa la capa de validación.

participant "quality_rules.py" as QR
' Participante que representa la política declarativa de calidad.

participant "writers.py" as W
' Participante que representa el módulo de persistencia Silver.

database "Silver\nsensor_events/" as SI
' Recurso de salida: el dataset persistido en Silver.

== Arranque ==
' Separador visual de etapa.
' Todo lo que sigue corresponde al encendido del sistema.

U -> RP : Ejecuta scripts/run_pipeline.py
' El usuario dispara el sistema desde terminal.

activate RP
' Marca que run_pipeline.py está "activo" en la secuencia.

RP -> RP : Calcula raíz del proyecto
' Acción interna del propio run_pipeline.py.
' No llama a otro módulo; resuelve su propia ubicación en el repo.

RP -> RP : Agrega src a sys.path
' Otra acción interna.
' Hace visible el paquete del proyecto para Python.

RP -> M : Importa main y llama main()
' Transferencia de control desde el bootstrapper al punto de entrada real.

deactivate RP
' run_pipeline.py deja de ser protagonista.
' El control principal pasa a main.py.

== Orquestación global ==
' Nueva etapa: ciclo de vida global de la aplicación.

activate M
' main.py queda activo.

M -> S : Importa SPARK_APP_NAME,\nSPARK_MASTER,\nNOMBRE_PIPELINE
' main.py consume configuración centralizada desde settings.py.

M -> LG : obtener_logger()
' Pide el logger del proyecto.

LG --> M : logger
' logger.py devuelve el objeto logger configurado.

M -> LG : info("Inicia la aplicación principal...")
' Primer gran log del flujo principal.

M -> M : crear_spark_session()
' main.py llama a su propia función interna de creación de Spark.

activate M
' Se representa la entrada a esa subrutina.

M -> S : Lee SPARK_APP_NAME y SPARK_MASTER
' La creación de Spark usa parámetros de settings.py.

M -> M : SparkSession.builder\n.appName(...)\n.master(...)\n.getOrCreate()
' Acción interna: se crea o recupera la SparkSession.

deactivate M
' Se sale de la subrutina crear_spark_session().

M -> LG : info("SparkSession creada correctamente")
' main.py registra que Spark quedó lista.

M -> P : ejecutar_todos_los_pipelines(spark)
' main.py delega el procesamiento del lote completo en pipelines.py.

== Lote completo ==
' Etapa de orquestación dataset por dataset.

activate P
' pipelines.py queda activo.

P -> LG : info("Inicia la ejecución completa...")
' Log de comienzo del lote.

P -> P : ejecutar_pipeline_sensor_events(spark)
' Selecciona el pipeline específico del dataset sensor_events.

P -> P : procesar_dataset_bronze_a_silver(spark, "sensor_events")
' Entra en la función general que procesa un dataset Bronze -> Silver.

P -> LG : info("Inicia el procesamiento del dataset: sensor_events")
' Log específico de inicio de sensor_events.

== Lectura Bronze ==
' Etapa de ingestión de sensor_events.

P -> R : leer_dataset_bronze(spark, "sensor_events")
' pipelines.py delega la lectura a readers.py.

activate R
' readers.py queda activo.

R -> S : obtener_ruta_dataset_bronze("sensor_events")
' readers.py consulta la ruta Bronze desde la configuración.

S --> R : ruta Bronze de sensor_events
' settings.py devuelve la ruta física del CSV Bronze.

R -> SC : obtener_esquema_dataset("sensor_events")
' readers.py pide el esquema estructural correspondiente.

SC --> R : ESQUEMA_SENSOR_EVENTS
' schemas.py devuelve el StructType esperado para sensor_events.

R -> B : spark.read\n.option(header, sep, formatos)\n.schema(esquema)\n.csv(ruta)
' Acción central de lectura:
' 1) usa spark.read
' 2) define opciones de parsing
' 3) impone esquema
' 4) concreta la lectura CSV

B --> R : datos CSV
' El archivo Bronze provee el contenido leído.

R --> P : df (DataFrame de sensor_events)
' readers.py devuelve el DataFrame ya estructurado a pipelines.py.

deactivate R
' readers.py deja de estar activo en esta parte del flujo.

P -> P : cantidad_registros = df.count()
' pipelines.py cuantifica cuántas filas fueron leídas.

P -> LG : info("Lectura completada con N registros")
' Registra la trazabilidad de volumen leído.

== Validación ==
' Etapa de control de calidad.

P -> V : ejecutar_validaciones_dataset(df, "sensor_events")
' pipelines.py delega las validaciones al módulo correspondiente.

activate V
' validators.py queda activo.

V -> QR : obtener_reglas_dataset("sensor_events")
' validators.py consulta la política declarativa del dataset.

QR --> V : REGLAS_CALIDAD["sensor_events"]
' quality_rules.py devuelve el bloque completo de reglas de sensor_events.

V -> V : validar_dataset_no_vacio(df)
' Primera validación: que el dataset no esté vacío.

V -> V : validar_columnas_requeridas(df, reglas)
' Segunda validación: que estén todas las columnas obligatorias.

V -> V : validar_columnas_no_nulas(df, reglas)
' Tercera validación: que ciertas columnas no tengan nulos.

V -> V : validar_valores_permitidos(df, reglas)
' Cuarta validación: catálogos y dominios permitidos.

V -> V : validar_rangos_numericos(df, reglas)
' Quinta validación: límites mínimos y máximos.
' En sensor_events, metric_value depende de metric_name.

V -> V : validar_duplicados(df, reglas)
' Sexta validación: grupos duplicados según clave natural.

alt Validación correcta
    V --> P : OK
    ' Si todo sale bien, validators.py devuelve el control normalmente.
else Error de calidad
    V --> P : ValueError
    ' Si falla alguna regla, validators.py eleva excepción.
    P --> M : Propaga error
    ' pipelines.py no oculta el error; lo deja subir.
end
' Bloque alternativo: muestra los dos caminos posibles.

deactivate V
' validators.py deja de estar activo.

P -> LG : info("Validaciones completadas correctamente")
' Este log corresponde solo al camino exitoso.

== Escritura Silver ==
' Etapa de persistencia final del dataset.

P -> W : escribir_dataset_silver(df, "sensor_events")
' pipelines.py delega la salida a writers.py.

activate W
' writers.py queda activo.

W -> S : obtener ruta Silver + modo + formato
' writers.py consulta la topología y la política de salida.

S --> W : DATASETS_SILVER["sensor_events"],\noverwrite, parquet
' settings.py devuelve:
' - ruta Silver
' - modo de escritura
' - formato de salida

W -> W : asegurar_carpeta_padre_salida(...)
' Acción interna: se asegura la existencia de la carpeta padre.

W -> SI : df.write.mode("overwrite").parquet(ruta_salida)
' Acción central de persistencia:
' el DataFrame se materializa en Parquet dentro de Silver.

SI --> W : persistencia completada
' Se representa la confirmación de escritura.

W --> P : OK
' writers.py devuelve el control a pipelines.py.

deactivate W
' writers.py deja de estar activo.

P -> LG : info("Escritura completada en silver")
' Log de escritura exitosa.

P -> LG : info("Finaliza el procesamiento del dataset: sensor_events")
' Cierre del flujo individual de sensor_events.

P -> LG : info("Finaliza la ejecución completa...")
' Cierre del lote completo desde pipelines.py.

deactivate P
' pipelines.py deja de estar activo.

== Cierre ==
' Etapa final de liberación de recursos.

M -> LG : info("La ejecución completa finalizó correctamente")
' main.py registra el cierre exitoso general.

M -> M : spark.stop()
' main.py libera la SparkSession.

M -> LG : info("SparkSession detenida correctamente")
' Log de cierre técnico de Spark.

M -> LG : info("Finaliza la aplicación principal...")
' Último log del flujo normal.

deactivate M
' main.py deja de estar activo.
@enduml
' Fin del diagrama.
